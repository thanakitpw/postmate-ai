# Playwright Service Environment Variables

# Server port
PORT=4000

# API secret — must match VPS_API_SECRET in the Next.js app
API_SECRET=your-api-secret-here

# Supabase — for saving post results and uploading screenshots
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session encryption key — must match SESSION_ENCRYPTION_KEY in the Next.js app (64 hex chars = 32 bytes)
SESSION_ENCRYPTION_KEY=your-64-char-hex-key-here

# Browser mode — set to "true" for headless, "false" to see the browser
HEADLESS=false
